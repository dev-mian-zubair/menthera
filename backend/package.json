{
  "name": "menthera-app",
  "version": "0.1.0",
  "description": "Menthera App - Voice-enabled AI personas with real-time calling",
  "bin": {
    "main": "bin/menthera-app.ts"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "npm run build && cdk",
    "cdk:deploy": "npm run build && cdk deploy",
    "cdk:diff": "npm run build && cdk diff",
    "cdk:synth": "npm run build && cdk synth",
    "cdk:destroy": "npm run build && cdk destroy",
    "deploy:dev": "npm run build && cdk deploy --all --require-approval never",
    "deploy:staging": "npm run build && cdk deploy --all --require-approval never --context environment=staging",
    "deploy:prod": "npm run build && cdk deploy --all --require-approval never --context environment=prod",
    "seed:quests": "npm run build && node dist/seed/quests.js",
    "seed:agents": "npm run build && node dist/seed/agents.js"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.9",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "2.1024.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.55",
    "@ai-sdk/google": "^2.0.46",
    "@ai-sdk/openai": "^2.0.81",
    "@aws-sdk/client-cloudwatch": "^3.967.0",
    "@aws-sdk/client-dynamodb": "^3.868.0",
    "@aws-sdk/client-ecs": "^3.873.0",
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/client-secrets-manager": "^3.864.0",
    "@aws-sdk/client-sqs": "^3.864.0",
    "@aws-sdk/lib-dynamodb": "^3.868.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@clerk/backend": "^2.29.5",
    "@hono/clerk-auth": "^3.0.3",
    "ai": "^5.0.111",
    "aws-cdk-lib": "2.208.0",
    "aws-lambda": "^1.0.7",
    "constructs": "^10.0.0",
    "hono": "^4.9.10",
    "mem0ai": "^2.1.38",
    "svix": "^1.15.0",
    "uuid": "^13.0.0"
  }
}
