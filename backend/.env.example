# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Environment
NODE_ENV=development
ENVIRONMENT=dev

# External API Keys (Store these in AWS Systems Manager Parameter Store)
CLERK_SECRET_KEY=your_clerk_secret_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
DAILY_API_KEY=your_daily_api_key
MEM0_API_KEY=your_mem0_api_key
GEMINI_API_KEY=your_gemini_api_key
ASSEMBLY_AI_API_KEY=your_assembly_ai_api_key

# Application Configuration
API_DOMAIN=api.example.com

# Allowed CORS origins (comma-separated). Required for all deploys.
# The api-gateway-stack will refuse to synth if this is unset.
# See README for configuration guidance.
ALLOWED_ORIGINS=https://app.example.com

# Domain Configuration
DOMAIN_NAME=example.com
