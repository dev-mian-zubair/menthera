# Menthera Mobile — environment template
#
# Copy this file to .env and fill in real values before running the app.
# Every EXPO_PUBLIC_* variable is embedded into the client JS bundle at
# build time and is visible to end users — do NOT put server-side secrets
# here, only publishable / client-safe keys.

# ─── Expo / EAS identity ─────────────────────────────────────────────────
# These are required. app.config.ts will throw at resolve time if unset.
# Get these from your EAS dashboard: https://expo.dev/accounts/<you>/projects
EAS_PROJECT_ID=
EXPO_OWNER=

# ─── Bundle identifiers (optional, default to com.example.menthera) ──────
# Override these before publishing to App Store / Play Store. Once you pick
# a bundle identifier and ship it, changing it creates a new app listing.
IOS_BUNDLE_IDENTIFIER=com.example.menthera
ANDROID_PACKAGE=com.example.menthera

# ─── Backend API endpoints ───────────────────────────────────────────────
# The root URL for the Menthera backend REST API (API Gateway). Used by
# every screen that talks to the backend.
EXPO_PUBLIC_BASE_URL=https://api.example.com/dev

# Some call sites read EXPO_PUBLIC_API_URL instead of EXPO_PUBLIC_BASE_URL.
# Until the naming is unified, set both to the same value.
EXPO_PUBLIC_API_URL=https://api.example.com/dev

# The Lambda Function URL for streaming chat. This is a different host from
# the REST API because streaming responses require Lambda Function URLs
# (API Gateway REST cannot stream). Get this from the CDK output of
# MentheraMessage stack.
EXPO_PUBLIC_CHAT_URL=https://<your-lambda-function-url>.lambda-url.us-east-1.on.aws/

# Optional override for the onboarding endpoint. Falls back to
# EXPO_PUBLIC_BASE_URL if unset.
EXPO_PUBLIC_ONBOARDING_URL=

# ─── Clerk authentication ────────────────────────────────────────────────
# Publishable key from your Clerk dashboard. Safe to embed in client builds.
# https://dashboard.clerk.com/ → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ─── RevenueCat subscriptions ────────────────────────────────────────────
# Public SDK key. You need one per platform in production (see RevenueCat
# docs for iOS vs Android keys); this single value works for development.
# https://app.revenuecat.com/ → Project Settings → API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY=

# ─── OAuth redirect behavior ─────────────────────────────────────────────
# The URL scheme used for OAuth redirects back into the app. Should match
# `scheme` in app.config.ts (default: "menthera").
EXPO_PUBLIC_REDIRECT_SCHEME=menthera

# Set to "true" to use localhost during development OAuth flows. Leave
# unset or "false" for production and device testing.
EXPO_PUBLIC_PREFER_LOCALHOST=false
